# -----------------------------
# Environment / paths
# -----------------------------
# Prepend Homebrew / Linux common paths
{{- if eq .chezmoi.os "darwin" -}}
set-environment -g PATH "/opt/homebrew/bin:/usr/local/bin:/bin:/usr/bin"
{{ end }}
set-environment -g TMUX_PLUGIN_MANAGER_PATH "$HOME/.tmux/plugins"

# -----------------------------
# Basic terminal settings
# -----------------------------
set -g default-terminal "xterm-ghostty"
set -as terminal-features ",xterm-ghostty:RGB,xterm-ghostty:Smulx"
set -g base-index 1
setw -g pane-base-index 1
set -g history-limit 50000
set -g mouse on
set -g status-keys vi
set -g mode-keys vi
setw -g aggressive-resize off
setw -g clock-mode-style 24
set -s escape-time 0
set-option -g status on
set-option -g status-position top
set-option -g focus-events on
set -g set-clipboard on

# -----------------------------
# Key bindings
# -----------------------------
bind -N "Kill the current window" & kill-window
bind -N "Kill the current pane" x kill-pane

unbind n
unbind p
bind Tab last-window

bind Enter copy-mode
bind -T copy-mode-vi v send -X begin-selection
bind -T copy-mode-vi C-v send -X rectangle-toggle
bind -T copy-mode-vi Escape send -X cancel

# -----------------------------
# Window / status options
# -----------------------------
setw -g automatic-rename on
set -g renumber-windows on
set -g set-titles on
set-option -g set-titles-string "❐ #S ● #I #W"
set-option -g automatic-rename on
set-option -g automatic-rename-format '#{b:pane_current_path}'

# -----------------------------
# TPM plugins
# -----------------------------
set -g @plugin 'tmux-plugins/tpm'                   # Plugin manager
set -g @plugin 'odedlaz/tmux-onedark-theme'         # Theme
set -g @plugin 'nhdaly/tmux-better-mouse-mode'      # Improved mouse copy
set -g @plugin 'tmux-plugins/tmux-pain-control'     # Pane resizing
set -g @plugin 'tmux-plugins/tmux-resurrect'        # Manual save/restore (prefix+C-s / prefix+C-r)
set -g @plugin 'tmux-plugins/tmux-yank'             # Cross-platform clipboard (xclip/wl-copy/pbcopy/WSL clip.exe)
set -g @plugin 'tmux-plugins/tmux-prefix-highlight' # Status-bar indicator when prefix is pressed
set -g @plugin 'tmux-plugins/tmux-sensible'         # Sensible basic defaults

# -----------------------------
# Plugin-specific options
# -----------------------------
# Better mouse mode
set -g @scroll-without-changing-pane "on"

# Pain control (pane resizing)
set -g @pane_resize "10"

# -----------------------------
# Extra UI / behavior
# -----------------------------
# Optional: toggle mouse script
bind m run "cut -c3- '#{TMUX_CONF}' | sh -s _toggle_mouse"

# Reload tmux config
bind R source-file "~/.tmux.conf"

# -----------------------------
# Initialize TPM (always last)
# -----------------------------
run '~/.tmux/plugins/tpm/tpm'

# -----------------------------
# Binding overrides (must run AFTER TPM so plugin-bound keys are overwritten)
# -----------------------------
# tmux-pain-control binds prefix+C-h/C-l to pane navigation; we want window nav
bind -r C-h previous-window
bind -r C-l next-window
